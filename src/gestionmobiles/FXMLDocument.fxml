<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>

<BorderPane prefHeight="600" prefWidth="800" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gestionmobiles.FXMLDocumentController">
    <top>
        <GridPane hgap="10" style="-fx-padding: 10; -fx-background-color: rgb(150, 147, 110);" vgap="10">
            <Label style="-fx-font-weight: bold;" text="Marque :" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="cbMarque" prefHeight="25.0" prefWidth="119.0" GridPane.columnIndex="1" GridPane.rowIndex="0" />
            <Label style="-fx-font-weight: bold;" text="Modèle :" GridPane.rowIndex="1" />
            <TextField fx:id="tfModele" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <Label style="-fx-font-weight: bold;" text="Prix :" GridPane.rowIndex="2" />
            <TextField fx:id="tfPrix" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label style="-fx-font-weight: bold;" text="Quantité :" GridPane.rowIndex="3" />
            <TextField fx:id="tfQuantite" GridPane.columnIndex="1" GridPane.rowIndex="3" />
            <Label style="-fx-font-weight: bold;" text="Disponible :" GridPane.rowIndex="4" />
            <CheckBox fx:id="cbDispo" GridPane.columnIndex="1" GridPane.rowIndex="4" />
            <HBox spacing="10" GridPane.columnSpan="2" GridPane.rowIndex="5">
                <Button fx:id="btnAjouter" onAction="#ajouterMobile" style="-fx-background-color: RGB(145, 176, 201);" text="Ajouter" />
                <Button fx:id="btnModifier" onAction="#modifierMobile" style="-fx-background-color: RGB(155, 189, 164);" text="Modifier" />
                <Button fx:id="btnSupprimer" onAction="#supprimerMobile" style="-fx-background-color: RGB(201, 114, 97);" text="Supprimer" />
                <Button fx:id="btnActualiser" mnemonicParsing="false" onAction="#actualiser" style="-fx-background-color: RGB(145, 176, 201);" text="Actualiser" />
            </HBox>
         <Label prefHeight="27.0" prefWidth="85.0" style="-fx-font-weight: bold;" text="Rechercher :" GridPane.columnIndex="6" />
         <TextField fx:id="tfRecherche" onKeyReleased="#rechercher" GridPane.columnIndex="7" />
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
        </GridPane>
      
    </top>
    <center>
        <TableView fx:id="tableMobiles" style="-fx-padding: 10;">
            <columns>
                <TableColumn fx:id="colId" text="ID" />
                <TableColumn fx:id="colMarque" text="Marque" />
                <TableColumn fx:id="colModele" text="Modèle" />
                <TableColumn fx:id="colPrix" text="Prix" />
                <TableColumn fx:id="colQuantite" text="Quantité" />
                <TableColumn fx:id="colDispo" text="Disponible" />
            </columns>
        </TableView>
    </center>
</BorderPane>
